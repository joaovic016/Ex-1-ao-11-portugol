programa {
  funcao inicio() {
    
    inteiro numero
    
    escreva ("Digite um numero inteiro: ")
    leia(numero)
  
    se ((numero % 3 == 0 e numero % 5 != 0 ) ou (numero % 5 == 0 e numero % 3 != 0))
  {
    escreva("O numero atende a condicao ")
  }

  senao
  {
    escreva("O numero nao atende a condicao ")
  }
  }
}












  }
}
